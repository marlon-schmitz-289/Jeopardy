{
  "name": "jeopardy-game",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "electron:dev": "concurrently --kill-others \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build-only && electron-builder",
    "electron:build:portable": "npm run build-only && electron-builder --win portable && node -e \"const fs=require('node:fs');const paths=['release/win-unpacked','release/builder-debug.yml','release/builder-effective-config.yaml'];for(const p of paths){if(fs.existsSync(p))fs.rmSync(p,{recursive:true,force:true});}\""
  },
  "build": {
    "appId": "com.jeopardy.game",
    "productName": "Jeopardy",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.games"
    },
    "win": {
      "target": "portable",
      "artifactName": "Jeopardy-Portable-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "pinia": "^3.0.3",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.16.5",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.7.0",
    "concurrently": "^9.1.2",
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "npm-run-all2": "^8.0.4",
    "typescript": "~5.8.0",
    "vite": "^7.0.6",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vue-tsc": "^3.0.4",
    "wait-on": "^8.0.3"
  }
}
